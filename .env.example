# Database
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/oneonone_dev

# Seed (superuser connection for seeding -- bypasses RLS)
SEED_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/oneonone_dev

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_MASTER_KEY=

# Auth.js
AUTH_SECRET=              # Generate with: openssl rand -base64 33
AUTH_TRUST_HOST=true      # Required for non-Vercel deployments

# OAuth (optional -- leave empty to disable)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=1on1 <noreply@yourdomain.com>

# App
NEXT_PUBLIC_APP_URL=http://localhost:4300
