# Database
DATABASE_URL=postgresql://app_user:app_password@localhost:5432/oneonone_dev

# Seed (superuser connection for seeding -- bypasses RLS)
SEED_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/oneonone_dev

# Admin (superuser for auth flows -- registration, login, password reset bypass RLS)
DATABASE_ADMIN_URL=postgresql://postgres:postgres@localhost:5432/oneonone_dev

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_MASTER_KEY=

# Auth.js
AUTH_SECRET=              # Generate with: openssl rand -base64 33
AUTH_TRUST_HOST=true      # Required for non-Vercel deployments

# OAuth (optional -- leave empty to disable)
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ID=
AUTH_MICROSOFT_ENTRA_ID_SECRET=
AUTH_MICROSOFT_ENTRA_ID_ISSUER=

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=tls              # "tls" for STARTTLS on 587, "ssl" for implicit TLS on 465
SMTP_USERNAME=
SMTP_PASSWORD=
EMAIL_FROM=1on1 <noreply@yourdomain.com>

# AI (Anthropic via Vercel AI SDK)
ANTHROPIC_API_KEY=

# Inngest (background job pipelines)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# App
NEXT_PUBLIC_APP_URL=http://localhost:4300
